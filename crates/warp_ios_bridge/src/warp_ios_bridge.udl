namespace warp_ios_bridge {
    // Call at app startup to pre-warm the Tokio runtime so the first SSH
    // connection doesn't pay the initialization cost.
    void initialize_bridge();

    [Throws=SshError, Async]
    SshSession ssh_connect_with_password(string host, u16 port, string username, string password);

    [Throws=SshError, Async]
    SshSession ssh_connect_with_key(string host, u16 port, string username, string private_key_pem);
};

[Error]
enum SshError {
    "ConnectionFailed",
    "AuthFailed",
    "ChannelError",
    "Disconnected",
    "InvalidKey",
};

callback interface DataReceiver {
    void on_data(sequence<u8> data);
    void on_disconnect(string reason);
};

callback interface SessionEventReceiver {
    void on_bootstrapped(string shell, boolean fallback_mode);
    void on_preexec(string command, u64 block_id);
    void on_command_finished(i32 exit_code, u64 block_id);
    void on_precmd(string working_directory);
    void on_output_chunk(u64 block_id, sequence<u8> data);
    void on_status(string message);
};

interface SshSession {
    void send_data(sequence<u8> data);
    void resize(u16 cols, u16 rows);
    void set_receiver(DataReceiver receiver);
    void set_event_receiver(SessionEventReceiver receiver);

    [Async]
    void disconnect();
};
